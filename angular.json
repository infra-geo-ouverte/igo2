{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "igo2": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": false,
          "style": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "aot": true,
            "outputPath": "dist/igo2",
            "index": "src/index.html",
            "tsConfig": "src/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": ""
              },
              {
                "glob": "**/*",
                "input": "node_modules/@igo2/common/assets/",
                "output": "igo2/common/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@igo2/core/assets/",
                "output": "igo2/core/"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@igo2/core/theming/prebuilt-themes",
                "output": "igo2/core/theming/prebuilt-themes"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@igo2/geo/assets/",
                "output": "igo2/geo"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@igo2/core/locale/",
                "output": "locale/libs_locale",
                "ignore": ["**/*.core.json"]
              }
            ],
            "styles": ["src/styles.scss"],
            "scripts": [],
            "stylePreprocessorOptions": {
              "includePaths": [
                "src/style/partial",
                "src/app/pages/portal",
                "node_modules"
              ]
            },
            "allowedCommonJsDependencies": [
              "@turf",
              "bowser",
              "canvg",
              "file-saver",
              "flexsearch",
              "html-entities",
              "html2canvas",
              "jspdf",
              "jspdf-autotable",
              "jszip",
              "jwt-decode",
              "moment",
              "nosleep.js",
              "raf",
              "rbush",
              "rgbcolor",
              "striptags",
              "ts-md5",
              "typy"
            ],
            "browser": "src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "serviceWorker": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "development-link": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true,
              "tsConfig": "./tsconfig.link.json",
              "assets": [
                {
                  "glob": "**/*",
                  "input": "public",
                  "output": ""
                },
                {
                  "glob": "**/*",
                  "input": "../../packages/common/src/assets/",
                  "output": "igo2/common/"
                },
                {
                  "glob": "**/*",
                  "input": "../../dist/core/assets/",
                  "output": "igo2/core/"
                },
                {
                  "glob": "**/*",
                  "input": "../../packages/geo/src/assets/",
                  "output": "igo2/geo/"
                },
                {
                  "glob": "**/*",
                  "input": "../../dist/core/locale/",
                  "output": "locale/libs_locale",
                  "ignore": ["**/*.core.json"]
                }
              ]
            },
            "github": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.github.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "serviceWorker": false
            },
            "pwa": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.pwa.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "serviceWorker": "ngsw-config.json"
            }
          }
        },
        "serve": {
          "defaultConfiguration": "development",
          "builder": "@angular/build:dev-server",
          "options": {
            "host": "0.0.0.0",
            "port": 4201,
            "hmr": true,
            "proxyConfig": "proxy.conf.json",
            "buildTarget": "igo2:build"
          },
          "configurations": {
            "development": {
              "buildTarget": "igo2:build:development"
            },
            "development-link": {
              "buildTarget": "igo2:build:development-link"
            },
            "production": {
              "buildTarget": "igo2:build:production"
            },
            "github": {
              "buildTarget": "igo2:build:github"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "coverage": true,
            "tsConfig": "./src/tsconfig.spec.json"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"],
            "eslintConfig": "eslint.config.mjs"
          }
        },
        "e2e": {
          "builder": "@cypress/schematic:cypress",
          "options": {
            "configFile": "e2e/cypress.config.ts",
            "devServerTarget": "igo2:serve",
            "browser": "chrome"
          },
          "configurations": {
            "production": {
              "devServerTarget": "igo2:serve:production"
            },
            "local": {
              "watch": true,
              "headless": false
            }
          }
        }
      }
    },
    "igo2-e2e": {
      "root": "e2e/",
      "projectType": "application",
      "architect": {
        "e2e": {
          "builder": "@cypress/schematic:cypress",
          "options": {
            "devServerTarget": "igo2-e2e:serve",
            "watch": true,
            "headless": false
          },
          "configurations": {
            "production": {
              "devServerTarget": "igo2-e2e:serve:production"
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["e2e/**/*.ts"]
          }
        }
      }
    }
  },
  "cli": {
    "cache": {
      "enabled": false
    },
    "schematicCollections": ["@schematics/angular"],
    "analytics": false
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
